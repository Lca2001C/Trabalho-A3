# ============================================================================
# ConectaBem — Variáveis de Ambiente (EXEMPLO)
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no Git!
# ============================================================================

# Banco de dados — copie em Supabase > Settings > Database > URI
DATABASE_URL="postgresql://postgres:SUA_SENHA@db.xxxx.supabase.co:5432/postgres"

# JWT — use uma string longa e aleatória
JWT_SECRET="sua_frase_secreta_longa_aqui_2024"

# Porta local
PORT=3001

# URL do frontend em produção (para configuração do CORS)
FRONTEND_URL="https://seu-projeto.vercel.app"

# Cloudinary — encontre em cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="sua_api_secret"

# Resend — gere em resend.com > API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"

# Mercado Pago — copie em developers.mercadopago.com.br
MERCADOPAGO_TOKEN="TEST-xxxxxxxxxxxxxxxx"
